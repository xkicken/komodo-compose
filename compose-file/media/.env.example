# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# User/Group IDs (run `id` in terminal to find yours)
PUID=1000
PGID=1000

# Timezone (https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TZ=Pacific/Auckland

# Media paths (absolute paths recommended on Linux/Mac)
DOWNLOADS_PATH=./downloads
TV_PATH=./media/tv
MOVIES_PATH=./media/movies

# ─── Gluetun / VPN ───────────────────────────
# Mullvad WireGuard (replace with your provider's vars if different)
WIREGUARD_PRIVATE_KEY=your_wireguard_private_key_here
WIREGUARD_ADDRESSES=10.x.x.x/32
VPN_COUNTRY=Netherlands

# For OpenVPN providers instead, use:
# VPN_USER=your_vpn_username
# VPN_PASSWORD=your_vpn_password
