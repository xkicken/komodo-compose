# ─────────────────────────────────────────────
# arr-stack — .env
# Place on host — DO NOT commit to git
# ─────────────────────────────────────────────

# User / Group IDs
PUID=1000
PGID=1000

# Timezone
TZ=UTC

# ─── Volume roots ────────────────────────────
# APPDATA — config/state data (small, fast disk)
APPDATA=/opt/appdata
# MEDIA — media and torrent data (large disk)
MEDIA=/mnt/media

# ─── Gluetun / ProtonVPN WireGuard ───────────
WG_PUBLIC_KEY=your_wireguard_public_key_here
WG_PRIVATE_KEY=your_wireguard_private_key_here
WG_ENDPOINT_IP=x.x.x.x
WG_ADDRESSES=10.2.0.2/32
DNS_ADDRESS=10.2.0.1

# Subnets Gluetun allows outbound (LAN + Docker bridges)
FIREWALL_OUTBOUND_SUBNETS=192.168.1.0/24,10.0.0.0/16,172.21.0.0/16

# ─── Gluetun control server ──────────────────
# Used by the port manager healthcheck
CONTROL_SERVER_AUTH_KEY=your_control_server_auth_key